# Clé secrète JWT — à changer obligatoirement en production
SECRET_KEY=changez-cette-cle-en-production

# Mot de passe PostgreSQL — à changer en production
POSTGRES_PASSWORD=changez-ce-mot-de-passe

# Compte super admin créé automatiquement au premier démarrage
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# IA Gemini — optionnel si configuré depuis l'interface admin
GEMINI_API_KEY=votre-cle-api-gemini
GEMINI_MODEL=gemini-2.0-flash
